{
  "$schema": "http://json.schemastore.org/tsconfig",

  "compilerOptions": {
    "forceConsistentCasingInFileNames": true,
    "jsx": "react",
    "declaration": true,
    "sourceMap": true,
    "inlineSources": true,
    "experimentalDecorators": true,
    "strictNullChecks": true,
    "types": ["node"],

    "module": "esnext",
    "moduleResolution": "bundler",
    "target": "es2019",
    "lib": ["es2020"]
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules", "lib"]
}
