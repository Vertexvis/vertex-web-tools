{
  "name": "@vertexvis/build-tools",
  "version": "0.11.1",
  "description": "Build tools for web development",
  "license": "MIT",
  "author": "Vertex Developers <support@vertexvis.com> (https://developer.vertexvis.com)",
  "homepage": "https://github.com/Vertexvis/vertex-web-tools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vertexvis/vertex-web-tools.git"
  },
  "bugs": {
    "url": "https://github.com/Vertexvis/vertex-web-tools/issues"
  },
  "type": "module",
  "main": "./dist/bundle.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/bundle.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "bin/*",
    "dist/*",
    "!dist/**/__tests__",
    "LICENSE"
  ],
  "bin": {
    "build-web": "./bin/build-web.sh",
    "vertex-web-lint": "./bin/lint-eslint.sh"
  },
  "scripts": {
    "clean": "rm -fr ./dist && mkdir ./dist",
    "format": "yarn lint --fix",
    "lint": "eslint .",
    "prebuild": "yarn clean",
    "build": "./bin/build-web.sh",
    "test": "jest",
    "test:coverage": "yarn test --coverage"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^29.0.3",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@vertexvis/rollup-plugin-vertexvis-copyright": "0.5.1",
    "rollup-plugin-typescript2": "^0.37.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^22.20.0",
    "@types/rollup-plugin-peer-deps-external": "^2.2.6",
    "@vertexvis/eslint-config-vertexvis-typescript": "0.6.1",
    "@vertexvis/jest-config-vertexvis": "0.6.1",
    "eslint": "^8.6.0",
    "jest": "^30.4.2",
    "rollup": "^4.62.2",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "ts-jest": "^29.4.11",
    "tslib": "^2.8.1",
    "typescript": "^5.9.0"
  },
  "peerDependencies": {
    "rollup": "^4",
    "typescript": ">=5.2.0"
  },
  "engines": {
    "node": ">=22.22.2"
  }
}
