{
  "name": "@vertexvis/build-tools",
  "version": "0.10.2",
  "description": "Build tools for web development",
  "license": "MIT",
  "author": "Vertex Developers <support@vertexvis.com> (https://developer.vertexvis.com)",
  "homepage": "https://github.com/Vertexvis/vertex-web-tools#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Vertexvis/vertex-web-tools.git"
  },
  "bugs": {
    "url": "https://github.com/Vertexvis/vertex-web-tools/issues"
  },
  "type": "module",
  "main": "./dist/bundle.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/bundle.js"
    },
    "./package.json": "./package.json"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "sideEffects": false,
  "files": [
    "bin/*",
    "dist/*",
    "!dist/**/__tests__",
    "LICENSE"
  ],
  "bin": {
    "build-web": "./bin/build-web.sh",
    "vertex-web-lint": "./bin/lint-eslint.sh"
  },
  "scripts": {
    "clean": "rm -fr ./dist && mkdir ./dist",
    "format": "yarn lint --fix",
    "lint": "eslint .",
    "prebuild": "yarn clean",
    "build": "./bin/build-web.sh",
    "test": "jest",
    "test:coverage": "yarn test --coverage"
  },
  "dependencies": {
    "@rollup/plugin-commonjs": "^28.0.1",
    "@rollup/plugin-json": "^5.0.0",
    "@rollup/plugin-node-resolve": "^15.0.0",
    "@vertexvis/rollup-plugin-vertexvis-copyright": "0.4.3",
    "rollup-plugin-terser": "^7.0.2",
    "rollup-plugin-typescript2": "^0.37.0"
  },
  "devDependencies": {
    "@types/jest": "^27.4.0",
    "@types/node": "^20.0.0",
    "@types/rollup-plugin-peer-deps-external": "^2.2.6",
    "@vertexvis/eslint-config-vertexvis-typescript": "0.5.2",
    "@vertexvis/jest-config-vertexvis": "0.5.6",
    "eslint": "^8.6.0",
    "jest": "^27.4.7",
    "rollup": "^2.80.0",
    "rollup-plugin-peer-deps-external": "^2.2.4",
    "ts-jest": "^27.1.2",
    "tslib": "^2.4.0",
    "typescript": "^5.2.0"
  },
  "peerDependencies": {
    "rollup": "^2"
  }
}
